@{
    ViewData["Title"] = "Job Durumu Takibi";
}

@* Anti-forgery token ekle *@
@Html.AntiForgeryToken()

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Aktif İşlemler</h3>
                    <button class="btn btn-primary btn-sm float-right" onclick="refreshJobs()">Yenile</button>
                </div>
                <div class="card-body">
                    <div id="jobList">
                        <!-- Jobs will be loaded here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function refreshJobs() {
    fetch('/Admin/GetAllJobStatuses')
        .then(response => response.json())
        .then(data => {
            updateJobList(data);
        });
}

function updateJobList(jobs) {
    const jobList = document.getElementById('jobList');
    
    // jobs null veya undefined kontrolü
    if (!jobs || Object.keys(jobs).length === 0) {
        jobList.innerHTML = '<p class="text-muted">Şu anda aktif işlem yok.</p>';
        return;
    }
    
    let html = '';
    let index = 0;
    // Dictionary olarak işle (Object.entries kullan)
    Object.entries(jobs).forEach(([jobId, status]) => {
        // Status kontrolü
        const jobStatus = status.Status || 'Unknown';
        const jobMessage = status.Message || 'Mesaj yok';
        const jobProgress = status.Progress || 0;
        
        // Tarih kontrolü ve formatı
        let formattedDate = 'Bilinmiyor';
        if (status.UpdatedAt) {
            try {
                const date = new Date(status.UpdatedAt);
                if (!isNaN(date.getTime())) {
                    formattedDate = date.toLocaleString('tr-TR');
                }
            } catch (e) {
                console.error('Tarih formatı hatası:', e);
            }
        }
        
        const progressClass = jobStatus === 'Running' ? 'progress-bar-animated' : '';
        const statusClass = jobStatus === 'Running' ? 'badge-primary' : 
                           jobStatus === 'Completed' ? 'badge-success' : 
                           jobStatus === 'Cancelled' ? 'badge-warning' : 'badge-danger';
        
        html += `
            <div class="job-item border rounded p-3 mb-3">
                <div class="row">
                    <div class="col-md-8">
                        <h5>İşlem #${index + 1} (${jobId})</h5>
                        <p class="mb-1">${jobMessage}</p>
                        <small class="text-muted">Son Güncelleme: ${formattedDate}</small>
                    </div>
                    <div class="col-md-4 text-right">
                        <span class="badge ${statusClass} mb-2">${jobStatus}</span>
                        <div class="progress mb-2">
                            <div class="progress-bar ${progressClass}" style="width: ${jobProgress}%">
                                %${jobProgress}
                            </div>
                        </div>
                        ${jobStatus === 'Running' ? `<button class="btn btn-sm btn-danger" onclick="cancelJob('${jobId}')">İptal Et</button>` : ''}
                    </div>
                </div>
            </div>
        `;
        index++;
    });
    jobList.innerHTML = html;
}

function cancelJob(jobId) {
    if (confirm('Bu işlemi iptal etmek istediğinizden emin misiniz?')) {
        // Anti-forgery token ekle
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        
        fetch('/Admin/CancelJob', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({ jobId: jobId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                refreshJobs();
            } else {
                alert('İşlem iptal edilemedi!');
            }
        })
        .catch(error => {
            console.error('Hata:', error);
            alert('Bir hata oluştu!');
        });
    }
}

// Auto refresh every 5 seconds
setInterval(refreshJobs, 5000);

// Initial load
refreshJobs();
</script>